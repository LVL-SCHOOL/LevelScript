ВКЛЮЧИТЬ стандартная_библиотека._.game
ВКЛЮЧИТЬ стандартная_библиотека.структуры.примитивные_структуры
ВКЛЮЧИТЬ стандартная_библиотека.типы
ВКЛЮЧИТЬ стандартная_библиотека.строки


ОПРЕДЕЛИТЬ КЛАСС Игра (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) (название_игры) (
        ссылка:название_игры = название_игры;
        ссылка:окно = ПУСТОТА;
        ссылка:работает = ИСТИНА;
        ссылка:клавиши = _таблица_клавиш();
        ссылка:типы_событий = _таблица_событий();
        _инициализация_игрового_движка();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) создать_экран(ширина=1920, высота=1080) (
        ссылка:окно = _создать_окно(ширина, высота);
        _заголовок_окна(ссылка:название_игры);
        ВЕРНУТЬ ссылка:окно;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) получить_события() (
        ВЕРНУТЬ _получить_событие();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) залить_экран(цвет) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _заливка_окна(ссылка:окно, цвет);
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) загрузить_картинку(путь) (
        ВЕРНУТЬ _загрузить_изображение(путь);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) отобразить_картинку(картинка, x, y) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _отобразить_картинку(ссылка:окно, картинка, массив(x, y));
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) обновить_экран() (
        _обновление_экрана();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) задержка(миллисекунды) (
        _задержка(миллисекунды);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) получить_время_игры() (
        ВЕРНУТЬ _получить_время();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) получить_позицию_мыши() (
        ВЕРНУТЬ _получить_позицию_мыши();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нажата_клавиша(код_клавиши) (
        ВЕРНУТЬ _нажата_ли_клавиша(код_клавиши);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нажата_кнопка_мыши(номер_кнопки) (
        ВЕРНУТЬ _нажата_ли_кнопка_мыши(номер_кнопки);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нажата_клавиша_по_имени(имя_клавиши) (
        ЗАДАТЬ код = извлечь_из_таблицы(ссылка:клавиши, имя_клавиши);
        ЕСЛИ код РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ форматировать_строку("Ошибка: неизвестное имя клавиши '{}'", имя_клавиши);
            ВЕРНУТЬ ЛОЖЬ;
        )
        ВЕРНУТЬ _нажата_ли_клавиша(код);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) создать_прямоугольник(x, y, ширина, высота) (
        ВЕРНУТЬ _создать_прямоугольник(x, y, ширина, высота);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нарисовать_прямоугольник(прямоугольник, цвет, толщина=1) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _нарисовать_прямоугольник(ссылка:окно, прямоугольник, цвет, толщина);
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нарисовать_круг(цвет, x, y, радиус) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _нарисовать_круг(ссылка:окно, цвет, x, y, радиус);
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) нарисовать_линию(цвет, x1, y1, x2, y2) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _нарисовать_линию(ссылка:окно, цвет, x1, y1, x2, y2);
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) создать_текст(текст, размер, цвет) (
        ВЕРНУТЬ _создать_текст(текст, размер, цвет);
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) отобразить_текст(текстовый_объект, x, y) (
        ЕСЛИ ссылка:окно РАВНО ПУСТОТА ТО (
            НАПЕЧАТАТЬ "Ошибка: экран не создан!";
            ВЕРНУТЬ ЛОЖЬ;
        )
        _отобразить_текст(ссылка:окно, текстовый_объект, x, y);
        ВЕРНУТЬ ИСТИНА;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) игровой_цикл(функция_обновления, функция_отрисовки, кадры_в_секунду=60) (
        ЗАДАТЬ время_кадра = 1000 / кадры_в_секунду;
        ЗАДАТЬ предыдущее_время = ссылка:получить_время_игры();
        ЗАДАТЬ текущее_время;
        ЗАДАТЬ дельта_время;
        ЗАДАТЬ событие;
        ЗАДАТЬ события;

        ПОКА ссылка:работает (
            текущее_время = ссылка:получить_время_игры();
            дельта_время = текущее_время - предыдущее_время;

            ЕСЛИ (дельта_время БОЛЬШЕ время_кадра) ИЛИ (дельта_время РАВНО время_кадра) ТО (
                события = ссылка:получить_события();

                ЦИКЛ счет ОТ 0 ДО длина_массива(события) - 1 (
                    событие = достать_из_массива(события, счет);
                    КОНТЕКСТ (
                        ЕСЛИ событие:это_выход ТО (
                            ссылка:работает = ЛОЖЬ;
                            ПРЕРВАТЬ;
                        )
                    )
                    ОБРАБОТЧИК БазоваяОшибка КАК _ (
                        ПРОПУСТИТЬ;
                    )
                )

                ЕСЛИ НЕ ссылка:работает ТО (
                    ПРЕРВАТЬ;
                )

                ЕСЛИ это_процедура(функция_обновления) ТО (
                    функция_обновления(дельта_время / 1000, события);
                )

                ЕСЛИ это_процедура(функция_отрисовки) ТО (
                    функция_отрисовки();
                )

                ссылка:обновить_экран();
                предыдущее_время = текущее_время;
            )
        )

        ссылка:завершить();
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) остановить() (
        ссылка:работает = ЛОЖЬ;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) завершить() (
        _выход_из_игры();
        НАПЕЧАТАТЬ форматировать_строку("Игра '{}' завершена.", ссылка:название_игры);
    )
)
