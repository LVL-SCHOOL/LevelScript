ВКЛЮЧИТЬ стандартная_библиотека.*

ОПРЕДЕЛИТЬ КЛАСС Тест (
)

ВЫПОЛНИТЬ (
    главная();
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ проц(значение) (
   ВЕРНУТЬ значение + 3;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ т = Тест();
    ЗАДАТЬ с = Список();

    ЦИКЛ i ОТ 1 ДО 10 (
        с:добавить(1);
    )

    с:для_каждого(проц);

    НАПЕЧАТАТЬ с:в_массив();
    !НАПЕЧАТАТЬ _;
    показать_узлы_сущности(главная);
)

