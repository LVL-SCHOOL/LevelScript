ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(счет, группировщик) (
   ! БЛОКИРОВАТЬ (
        ЖДАТЬ В ФОНЕ асинхронный_сон(1);
   ! )

    НАПЕЧАТАТЬ "привет из " + в_строку(счет);
    НАПЕЧАТАТЬ группировщик:_количество_задач ;
    группировщик:готов();
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ группировщик = ГруппировщикЗадач();
    группировщик:добавить(100);

    ЦИКЛ счет ОТ 1 ДО 100 (
        НАПЕЧАТАТЬ "СТАРТ: " + в_строку(счет);
        В ФОНЕ фон(счет, группировщик);
    )


    ЦИКЛ счет ОТ 1 ДО 10000 (
        НАПЕЧАТАТЬ "фигачим))))" + в_строку(счет);
    )
    !НАПЕЧАТАТЬ планировщик:результаты();
    группировщик:ждать();

)

ВЫПОЛНИТЬ (
    старт();
)
