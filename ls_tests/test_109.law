ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача() (
    ЦИКЛ ОТ 1 ДО 100 (
        2 + 2 * 2
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ задачи = Список();

    ЗАДАТЬ с = временная_метка()

    ЦИКЛ номер ОТ 1 ДО 12 (
       задачи:добавить(В ФОНЕ фоновая_задача());
    )

    ждать_всех(задачи:в_массив());
    НАПЕЧАТАТЬ временная_метка() - с

    с = временная_метка()
    ЦИКЛ номер ОТ 1 ДО 12 (
       фоновая_задача();
    )

    НАПЕЧАТАТЬ временная_метка() - с
)

ВЫПОЛНИТЬ (
    главная();
)
