ВКЛЮЧИТЬ стандартная_библиотека.конкурентность
ВКЛЮЧИТЬ стандартная_библиотека.интернет
ВКЛЮЧИТЬ стандартная_библиотека.строки
ВКЛЮЧИТЬ стандартная_библиотека.время
ВКЛЮЧИТЬ стандартная_библиотека.структуры.сложные_структуры


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача() (
    ЦИКЛ ОТ 1 ДО 100 (
        2 + 2 * 2
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ оз = ОтложенныйЗапуск()

    ЦИКЛ номер ОТ 1 ДО 100 (
       оз:добавить(фоновая_задача);
    )

    ЗАДАТЬ с = временная_метка()

    оз:запуск()

    НАПЕЧАТАТЬ временная_метка() - с

    с = временная_метка()
   ЦИКЛ номер ОТ 1 ДО 100 (
       фоновая_задача();
    )

    НАПЕЧАТАТЬ временная_метка() - с

    НАПЕЧАТАТЬ массив(массив(массив(1), массив(2)))
)

ВЫПОЛНИТЬ (
    главная();
)
