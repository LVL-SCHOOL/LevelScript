ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(счет) (
    НАПЕЧАТАТЬ "НАЧАЛО счет=" + в_строку(счет);
    спать(1);
    НАПЕЧАТАТЬ "КОНЕЦ счет=" + в_строку(счет);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон2(а, б, в) (
    ВЕРНУТЬ массив(а, б, в);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ п = ПланировщикЗадач();

    ЗАДАТЬ м = массив(1 , ЖДАТЬ В ФОНЕ фон2(1,2,3), 3);

    ЦИКЛ счет ОТ 1 ДО 100 (
        НАПЕЧАТАТЬ "ДОБАВИЛ счет=" + в_строку(счет);
        п:добавить(В ФОНЕ фон(счет));
    )


    НАПЕЧАТАТЬ "ВСЕХ ДОБАВИЛ!";
    п:результаты();
)

ВЫПОЛНИТЬ (
    старт();
)
