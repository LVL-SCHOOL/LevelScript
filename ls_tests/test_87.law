ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _сон(время_сна) (
    ЗАДАТЬ старт = временная_метка()

    ПОКА временная_метка() - старт МЕНЬШЕ время_сна (
        ПРОПУСТИТЬ
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сон(время_сна) (
    ВЕРНУТЬ В ФОНЕ _сон(время_сна)
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (

)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест() (
    ЗАДАТЬ старт = временная_метка()
    ЗАДАТЬ ранд = ГенераторСлучайныхЧисел()
    ЗАДАТЬ планировщик = ПланировщикЗадач()

    ЦИКЛ счет ОТ 1 ДО 100 (
        !планировщик:добавить(сон(0.1))
        !планировщик:добавить(В ФОНЕ асинхронный_сон(0.1))
    )

    планировщик:результаты()
    НАПЕЧАТАТЬ временная_метка() - старт
)

ВЫПОЛНИТЬ (
    тест()
)
