ВКЛЮЧИТЬ стандартная_библиотека.аргументы_запуска
ВКЛЮЧИТЬ стандартная_библиотека.структуры.*


ОПРЕДЕЛИТЬ КЛАСС ОшибкаВвода НАСЛЕДОВАТЬ ОТ БазоваяОшибка (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) (инфа) (
        ссылка:информация = инфа;
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ аргументы = получить_аргументы_запуска();

    ЦИКЛ счет ОТ 0 ДО длина_массива(аргументы) - 1 (
        НАПЕЧАТАТЬ достать_из_массива(аргументы, счет);
    )

    ЕСЛИ НЕ длина_массива(аргументы) ТО (
        ВЕРНУТЬ;
    )

    ЗАДАТЬ аргумент = достать_из_массива(аргументы, 0);
    ЗАДАТЬ значение = достать_из_массива(аргументы, 1);

    ЕСЛИ аргумент РАВНО "--test" ТО (
        ЕСЛИ значение РАВНО "hi" ТО (
            НАПЕЧАТАТЬ "Привет) Как дела?";
        )
        ИНАЧЕ ЕСЛИ значение РАВНО "bye" ТО (
            НАПЕЧАТАТЬ "Эх, пока-пока!";
        )
        ИНАЧЕ (
            ОШИБКА ОшибкаВвода("Вы ввели некорректное значение!");
        )
    )
)

ВЫПОЛНИТЬ (
    старт();
)
