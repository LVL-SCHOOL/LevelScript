ВКЛЮЧИТЬ стандартная_библиотека.интернет
ВКЛЮЧИТЬ стандартная_библиотека.конкурентность
ВКЛЮЧИТЬ стандартная_библиотека.ввод_вывод
ВКЛЮЧИТЬ стандартная_библиотека.аргументы_запуска
ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ рендер_страницы(маршрут, запрос) (
    ЗАДАТЬ контекст = Контекст()

    ЗАДАТЬ кеш = контекст:достать_без_блокировки("тело")

    ЕСЛИ кеш НЕРАВЕН ПУСТОТА ТО (
        ВЕРНУТЬ кеш
    )

    ЗАДАТЬ тело = ""
    ЗАДАТЬ сырой_html

    КОНТЕКСТ (
        сырой_html = прочитать_файл("index.html")
    )
    ОБРАБОТЧИК ОшибкаФайла КАК _ (
        ВЕРНУТЬ "<html><body><h1>Файл не найден</h1></body></html>"
    )

    ЦИКЛ счет ОТ 0 ДО длина_массива(сырой_html) - 1 (
        тело = тело + достать_из_массива(сырой_html, счет)
    )

    контекст:положить("тело", тело)

    ВЕРНУТЬ тело
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ обработчик_тест(маршрут, запрос) (
   ! ЗАДАТЬ с  = временная_метка()
    ЗАДАТЬ тело = рендер_страницы(маршрут, запрос)
    ЗАДАТЬ ключи_заголовков = массив(
        "Content-type",
    )
    ЗАДАТЬ значения_заголовков = массив(
        "text/html; charset=utf-8",
    )
    ЗАДАТЬ заголовки = таблица(ключи_заголовков, значения_заголовков)

   ! НАПЕЧАТАТЬ  форматировать_строку("GET: {}", временная_метка() - с)
    ВЕРНУТЬ Ответ(
        тело,
        заголовки,
        200
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ обработчик_тест_POST(маршрут, запрос) (
    ЗАДАТЬ тело = (
        "<html>" +
        "<head><title>HTTP сервер</title></head>" +
        "<body>" +
        "<h1>ВСЕМ ПРИВЕТ от POST!</h1>" +
        "</body>" +
        "</html>",
    )
    ЗАДАТЬ ключи_заголовков = массив(
        "Content-type",
    )
    ЗАДАТЬ значения_заголовков = массив(
        "text/html; charset=utf-8",
    )
    ЗАДАТЬ заголовки = таблица(ключи_заголовков, значения_заголовков)

    ВЕРНУТЬ Ответ(
        тело,
        заголовки,
        200
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ быстрая_сортировка(массив_для_сортировки, низ, верх) (
    ЕСЛИ низ МЕНЬШЕ верх ТО (
        ЗАДАТЬ опорный_индекс = разделить(
            массив_для_сортировки,
            низ,
            верх,
        );
        быстрая_сортировка(
            массив_для_сортировки,
            низ,
            опорный_индекс - 1,
        );
        быстрая_сортировка(
            массив_для_сортировки,
            опорный_индекс + 1,
            верх,
        );
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ разделить(массив_для_сортировки, низ, верх) (
    ЗАДАТЬ опорный_элемент = достать_из_массива(
        массив_для_сортировки,
        верх,
    );
    ЗАДАТЬ i = низ - 1;

    ЦИКЛ j ОТ низ ДО верх - 1 (
      !  ЖДАТЬ В ФОНЕ асинхронный_сон(1)
        ЕСЛИ достать_из_массива(массив_для_сортировки, j) МЕНЬШЕ опорный_элемент ТО (
            i = i + 1;
            ЗАДАТЬ временный = достать_из_массива(
                массив_для_сортировки,
                i,
            );
            ЗАДАТЬ значение_j = достать_из_массива(
                массив_для_сортировки,
                j,
            );
            изменить_в_массиве(
                массив_для_сортировки,
                i,
                значение_j,
            );
            изменить_в_массиве(
                массив_для_сортировки,
                j,
                временный,
            );
        )
    )

    ЗАДАТЬ временный = достать_из_массива(
        массив_для_сортировки,
        i + 1,
    );
    ЗАДАТЬ значение_верх = достать_из_массива(
        массив_для_сортировки,
        верх,
    );
    изменить_в_массиве(
        массив_для_сортировки,
        i + 1,
        значение_верх,
    );
    изменить_в_массиве(
        массив_для_сортировки,
        верх,
        временный,
    );

    ВЕРНУТЬ i + 1;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ отсортировать(массив_для_сортировки) (
    быстрая_сортировка(
        массив_для_сортировки,
        0,
        длина_массива(массив_для_сортировки) - 1,
    );
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест_сортировки() (
    ЗАДАТЬ числа = массив(
        64,
        34,
        25,
        12,
        22,
        11,
        90,
        5,
    );

    НАПЕЧАТАТЬ форматировать_строку(
        "До сортировки: \n{}",
        числа,
    )

    отсортировать(числа);

    НАПЕЧАТАТЬ форматировать_строку(
        "После сортировки: \n{}",
        числа,
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача(счет) (
    ЗАДАТЬ начать_печать_теста = ИСТИНА

    !начать_печать_теста = начать_печать_теста
    начать_печать_теста = НЕ начать_печать_теста

    ЗАДАТЬ числа


    ПОКА начать_печать_теста (
        тест_сортировки()
    )

    ПОКА НЕ начать_печать_теста (
       ! НАПЕЧАТАТЬ счет
        числа = массив(
            64,
            34,
            25,
            12,
            22,
            11,
            90,
            5,
        );


        отсортировать(числа);
    )

)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача2(счет) (

    ПОКА ИСТИНА (
        ЦИКЛ ОТ 1 ДО 1000 (
            2+ 2 * 2
        )
    )

)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ запуск_фона() (
    ЗАДАТЬ с

    ЦИКЛ счет ОТ 1 ДО 100000 (
        с  = временная_метка()
        НАПЕЧАТАТЬ счет
        В ФОНЕ фоновая_задача(счет)
        НАПЕЧАТАТЬ  временная_метка() -с
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
  !  В ФОНЕ запуск_фона()

    ЗАДАТЬ с
    ЦИКЛ счет ОТ 1 ДО 10000 (
       ! с  = временная_метка()
        НАПЕЧАТАТЬ счет
      В ФОНЕ фоновая_задача(счет)
     !  НАПЕЧАТАТЬ  временная_метка() -с
   )
    ЗАДАТЬ движок
    ЗАДАТЬ флаг_движка
    ЗАДАТЬ аргументы = получить_аргументы_запуска()

    ЕСЛИ НЕ аргументы ТО (
        движок = синхронный_серверный_движок()
        НАПЕЧАТАТЬ форматировать_строку(
            "Не указан флаг запуска, по умолчанию будет использован синхронный серверный движок\n" +
            "Чтобы выбрать режим работы сервера укажите 'sync', 'async' или 'thread'\n"
        )
    )
    ИНАЧЕ (
        флаг_движка = достать_из_массива(аргументы, 0)

        ЕСЛИ флаг_движка РАВЕН "async" ТО (
            движок = асинхронный_серверный_движок()
        )
        ИНАЧЕ ЕСЛИ флаг_движка РАВЕН "sync" ТО (
            движок = синхронный_серверный_движок()
        )
        ИНАЧЕ ЕСЛИ флаг_движка РАВЕН "thread" ТО (
            движок = многопоточный_серверный_движок()
        )
        ИНАЧЕ (
            НАПЕЧАТАТЬ форматировать_строку(
                "Указан неверный флаг запуска, по умолчанию будет использован синхронный серверный движок\n" +
                "Чтобы выбрать режим работы сервера укажите 'sync', 'async' или 'thread'\n"
            )
        )
    )

    НАПЕЧАТАТЬ форматировать_строку("Используется HTTP движок: {}\n", движок)

    ЗАДАТЬ обработчик = Обработчик()
    обработчик:добавить_GET_маршрут("/hello", обработчик_тест)
    обработчик:добавить_POST_маршрут("/hello", обработчик_тест_POST)

    ЗАДАТЬ сервер = Сервер("localhost", 5050, обработчик, движок)

    сервер:запуск()
)

ВЫПОЛНИТЬ (
   главная()
)
