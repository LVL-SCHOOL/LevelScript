ОПРЕДЕЛИТЬ КЛАСС бАЗОЫВЙТест (
    ОПРЕДЕЛИТЬ МЕТОД (_) тест2(аргсы...) (
        НАПЕЧАТАТЬ "МЕТОД тест2"
        НАПЕЧАТАТЬ аргсы
    )
)

ОПРЕДЕЛИТЬ КЛАСС Тест НАСЛЕДОВАТЬ ОТ бАЗОЫВЙТест (
    ОПРЕДЕЛИТЬ МЕТОД (_) тест(аргсы...) (
        НАПЕЧАТАТЬ "МЕТОД тест"
        НАПЕЧАТАТЬ аргсы
    )

    ОПРЕДЕЛИТЬ КОНСТРУКТОР (_) (аргсы...) (
        НАПЕЧАТАТЬ "КОНСТРУКТОР"
        НАПЕЧАТАТЬ аргсы
    )
)



ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт (аргументы...) (
    НАПЕЧАТАТЬ "ПРОЦЕДУРУ старт"
    НАПЕЧАТАТЬ аргументы

    ЗАДАТЬ т = Тест(
        1,
        2,
        3,
    )


    т:тест()
    т:тест(1)
    т:тест(1,2,3)
    т:тест(
    1,2,3)
    т:тест2()
    т:тест2(1)
    т:тест2(1,2,3)
    т:тест2(
    1,2,3)
)

ВЫПОЛНИТЬ (
    старт()
)
