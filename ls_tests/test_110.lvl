ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) () (
        ссылка:икс = 1
    )

    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) СЛОЖЕНИЕ (число) (
        ссылка:икс = ссылка:икс + 1

        ВЕРНУТЬ ссылка
    )
)

ОПРЕДЕЛИТЬ КЛАСС Тест2 НАСЛЕДОВАТЬ ОТ Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) () (
        ссылка:__родитель__:__конструктор__()
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (
    ЦИКЛ счет ОТ 1 ДО 100 (
        НАПЕЧАТАТЬ счет
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест() (
    ЗАДАТЬ с = Список()

    ЦИКЛ ОТ 1 ДО 10 (
       ! с:добавить(В ФОНЕ фон())
    )

    !ОТЛОЖИТЬ ждать_всех(с:в_массив())
    ОТЛОЖИТЬ вывод("выход из функции!")
    ЗАДАТЬ мас1 = массив()
    ЗАДАТЬ мас2 = массив()

    добавить_в_массив(мас1, мас2)
    добавить_в_массив(достать_из_массива(мас1, 0), мас1)

    НАПЕЧАТАТЬ мас1

    ЗАДАТЬ т = Тест2()
    ЗАДАТЬ т2 = Тест2()

    т = т + т2
    НАПЕЧАТАТЬ т:икс
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест1() (
 тест()
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
   тест1();тест1();тест1()
)

ВЫПОЛНИТЬ (
    главная();
)

