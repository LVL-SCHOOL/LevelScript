ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (
    ВЕРНУТЬ 1
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    НАПЕЧАТАТЬ НЕ В ФОНЕ фон()
    НАПЕЧАТАТЬ В ФОНЕ фон()

    !ПОКА (НЕ ЖДАТЬ В ФОНЕ фон()) (
     !   вывод(1)
    !)
    НАПЕЧАТАТЬ ввод(">>>")
    ЗАДАТЬ в= 1
    !НАПЕЧАТАТЬ 1 И + 0 - И 1;
   ! НАПЕЧАТАТЬ "123123123123123s" + (2 + 2 * 2  ) - в 2 * 2
   !НАПЕЧАТАТЬ "123123123123123s" + (2 + 2 * 2  ) - в в * 2
  !  НАПЕЧАТАТЬ "123123123123123s" + (2 + 2 * 2  ) - 1 2 * 2
    !НАПЕЧАТАТЬ 1 И НЕ 2;     ! ок
    !НАПЕЧАТАТЬ 1 И 5 БОЛЬШЕ 3;
    ! () / ()
    !"123123123123123s"  - ЖДАТЬ + 1 + "123123123123123s"

)

ВЫПОЛНИТЬ (
    главная()
)
