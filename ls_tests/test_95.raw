ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (
    ВЕРНУТЬ 1
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ пер
    ! === Уже есть ===
    НАПЕЧАТАТЬ НЕ В ФОНЕ фон()
    НАПЕЧАТАТЬ В ФОНЕ фон()
    !НАПЕЧАТАТЬ "123123123123123s" + (2 + 2 * 2  ) - 1 2 * 2

    ! === check_wait: после ЖДАТЬ идёт ===
    ! НАПЕЧАТАТЬ ЖДАТЬ 1;
    ! НАПЕЧАТАТЬ ЖДАТЬ +;
    ! НАПЕЧАТАТЬ ЖДАТЬ ));
    ! НАПЕЧАТАТЬ ЖДАТЬ ИСТИНА;

    ! === check_math_ops: после + - * / ^ % идёт ===
    ! НАПЕЧАТАТЬ 1 + );
    ! НАПЕЧАТАТЬ 1 - И;
    ! НАПЕЧАТАТЬ 1 * РАВНО + 1;
    ! НАПЕЧАТАТЬ 1 / ,;
    ! НАПЕЧАТАТЬ 1 ^ ;;

    ! === check_bool_ops: после И ИЛИ РАВНО БОЛЬШЕ идёт хуйня ===
    ! НАПЕЧАТАТЬ 1 И ) + 1;
    ! НАПЕЧАТАТЬ 1 ИЛИ , + 1;
    ! НАПЕЧАТАТЬ 1 РАВНО * + 1;
    ! НАПЕЧАТАТЬ 1 БОЛЬШЕ / + 1;
    ! НАПЕЧАТАТЬ 1 МЕНЬШЕ ^ + 1;

    ! === check_right_bracket: после ) идёт хуйня ===
    ! НАПЕЧАТАТЬ (1 + 2) 5 + 1;
    ! НАПЕЧАТАТЬ (1 + 2) "строка" + 1;
    ! НАПЕЧАТАТЬ (1 + 2) переменная + 1;

    ! === Двойные операторы ===
    ! НАПЕЧАТАТЬ 1 + + 2 + 1;
    ! НАПЕЧАТАТЬ 1 И И 2 + 1;
    ! НАПЕЧАТАТЬ 1 РАВНО РАВНО 2 + 1;
    ! НАПЕЧАТАТЬ 1 * * 2 + 1;
    ! НАПЕЧАТАТЬ ЖДАТЬ ЖДАТЬ задача + 1;

    ! === Двойные запятые ===
    ! НАПЕЧАТАТЬ фон(1,, 2) + 1;
    ! НАПЕЧАТАТЬ фон(1,,, 3) + 1;
    ! НАПЕЧАТАТЬ массив(1,, 2,, 3) + 1;

    ! === Незакрытые скобки ===
    ! НАПЕЧАТАТЬ ((1 + 2);
    ! НАПЕЧАТАТЬ 1 + 2);
    ! НАПЕЧАТАТЬ (((1 + 2));

    ! === Выражение заканчивается оператором ===
    ! НАПЕЧАТАТЬ 1 +;
    ! НАПЕЧАТАТЬ 1 И;
    ! НАПЕЧАТАТЬ 1 БОЛЬШЕ;
    ! НАПЕЧАТАТЬ ЖДАТЬ;

    ! === Два значения подряд ===
    ! НАПЕЧАТАТЬ 1 2;
    ! НАПЕЧАТАТЬ "строка" 5;
    ! НАПЕЧАТАТЬ фон 1;
    ! НАПЕЧАТАТЬ ИСТИНА 5;
    ! НАПЕЧАТАТЬ 3.14 2.71;

    ! === Неизвестный токен ===
    ! НАПЕЧАТАТЬ @#$;
    ! НАПЕЧАТАТЬ 1 + @;

    ! === В ФОНЕ непарные ===
    ! НАПЕЧАТАТЬ В задача;
    ! НАПЕЧАТАТЬ ФОНЕ задача;
    ! НАПЕЧАТАТЬ В В ФОНЕ задача;

    ! === Унарные операторы после булевых (должны работать) ===
    НАПЕЧАТАТЬ 1 И -2;
    НАПЕЧАТАТЬ 1 ИЛИ +3;
    НАПЕЧАТАТЬ 1 И НЕ 2;
    НАПЕЧАТАТЬ 1 И (5 БОЛЬШЕ 3);

    НАПЕЧАТАТЬ 1:_
    НАПЕЧАТАТЬ пер:_:_:_:_:_:_:_:_:_:_:_:_:_:_:_:_
    НАПЕЧАТАТЬ ИСТИНА:_
    !НАПЕЧАТАТЬ И:_
)

ВЫПОЛНИТЬ (
    главная()
)
