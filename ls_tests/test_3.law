ОПРЕДЕЛИТЬ ПРОЦЕДУРУ func(a)(
    !func_wa(1, 2);

НАПЕЧАТАТЬ ИСТИНА НЕ РАВНО ИСТИНА;
НАПЕЧАТАТЬ 1 НЕ РАВНО 1;
НАПЕЧАТАТЬ 1 НЕ РАВНО 2;


НАПЕЧАТАТЬ "func";
НАПЕЧАТАТЬ 2 * (mul2(mul2(1 + 1) * 2) - 1);

    НАПЕЧАТАТЬ (НЕ ((ИСТИНА И ЛОЖЬ) ИЛИ ИСТИНА И НЕ ИСТИНА)) И ЛОЖЬ;
НАПЕЧАТАТЬ -(-(-(-(-(-1)))));
(1 БОЛЬШЕ 10000) ИЛИ (2 БОЛЬШЕ 100);
! to_string();
(1 + 10000) - (2 + 100);

       НАПЕЧАТАТЬ "" + в_строку(1 + 2);
       НАПЕЧАТАТЬ "" + в_строку(mul1()+ 2);
       НАПЕЧАТАТЬ "в_строку(mul2(mul1())+ 2);=" + в_строку(mul2(mul1())+ 2);

       ЗАДАТЬ ф = 1 + mul1() + mul(2, 3, 4) + mul(5, 6, 7);
       НАПЕЧАТАТЬ "ф=" + в_строку(ф);
    ЗАДАТЬ икс = mul;
    НАПЕЧАТАТЬ икс;
    НАПЕЧАТАТЬ икс(1,2,2);

    НАПЕЧАТАТЬ mul(9, mul(mul(3, 1, 2), 5, 4), 8);
   ЗАДАТЬ мас = (1+1);
   ЗАДАТЬ мас1 = массив(в_строку(mul2(mul1())+ 2),2,массив(1,2,3,4,массив(1,mul(9, mul(mul(3, 1, 2), 5, 4), 8),3,4)),4,массив(1,mul(9, mul(mul(3, 1, 2), 5, 4), 8),3,4));
    НАПЕЧАТАТЬ мас1;
    НАПЕЧАТАТЬ мас1;
    НАПЕЧАТАТЬ массив(1,2,3,4);
    ! print(1+1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,);
    НАПЕЧАТАТЬ мас;
    НАПЕЧАТАТЬ мас1;

    добавить_в_массив(мас1, 1);
    добавить_в_массив(мас1, массив(666,2 + 2 * 2,(2 + 2) * 2, ИСТИНА И НЕ ЛОЖЬ, ИСТИНА ИЛИ ИСТИНА И ЛОЖЬ));

    НАПЕЧАТАТЬ мас1;

    удалить_из_массива(мас1, 2);



    НАПЕЧАТАТЬ мас1;
    ! НАПЕЧАТАТЬ масasd;

    func4();
    ЗАДАТЬ b = 1;
НАПЕЧАТАТЬ ((2 + 2) * 2) - (2 + 2) * 2 + (b + 2) * b - (2 + 2) * 2 * b * b * b * b;

ЗАДАТЬ arr = массив(1,2,3, массив(1,2,3.1, в_строку(3.1)));

    НАПЕЧАТАТЬ достать_из_массива(arr, -1);
    ЗАДАТЬ item =  достать_из_массива(arr, -1);
НАПЕЧАТАТЬ "item=" + в_строку(item);

    НАПЕЧАТАТЬ arr;
    изменить_в_массиве(arr, -1, "2");
    НАПЕЧАТАТЬ arr;
    НАПЕЧАТАТЬ длина_массива(arr);

    НАПЕЧАТАТЬ пузырьковая_сортировка(массив(1,-3,10,0, 100, -1,-1));
    НАПЕЧАТАТЬ "в_строку(пузырьковая_сортировка(массив(1,-3,10,0, 100, -1,-1), mul2333()))=" + в_строку(пузырьковая_сортировка(массив(1,-3,10,0, 100, -1,-1)));


    ЗАДАТЬ ключи = массив("ключ1", "ключ2");
    ЗАДАТЬ значения = массив(1, массив(2, 3));
    ЗАДАТЬ табл = таблица(ключи, значения);

    НАПЕЧАТАТЬ табл;

    добавить_в_таблицу(табл, "к3", таблица(ключи, значения));
    НАПЕЧАТАТЬ "табл=";
    НАПЕЧАТАТЬ табл;

    НАПЕЧАТАТЬ извлечь_из_таблицы(табл, "ключ1");
    НАПЕЧАТАТЬ удалить_из_таблицы(табл, "ключ1");
    НАПЕЧАТАТЬ табл;
    НАПЕЧАТАТЬ длина_таблицы(табл);

    ЦИКЛ ОТ 1 ДО 10 (
        НАПЕЧАТАТЬ "без переменной цикла";
    )

    ЦИКЛ переменная_цикла ОТ 1 ДО 10 (
        НАПЕЧАТАТЬ "с переменной цикла " + в_строку(переменная_цикла);
    )


    НАПЕЧАТАТЬ (НЕ (ИСТИНА НЕ РАВНО ИСТИНА И ЛОЖЬ) НЕ РАВНО ИСТИНА) И (1 БОЛЬШЕ -1);
    НАПЕЧАТАТЬ (НЕ (ИСТИНА НЕРАВНО ИСТИНА И ЛОЖЬ) НЕРАВНО ИСТИНА) И (1 БОЛЬШЕ -1);
    НАПЕЧАТАТЬ ИСТИНА НЕРАВНО ИСТИНА И ЛОЖЬ;
    НАПЕЧАТАТЬ (ИСТИНА НЕРАВНО ИСТИНА) И ЛОЖЬ;

    НАПЕЧАТАТЬ пузырьковая_сортировка(массив());
    НАПЕЧАТАТЬ пузырьковая_сортировка(массив(1, 0, 0));

    ЗАДАТЬ ключи1 = массив("ключ1", "ключ2");
    ЗАДАТЬ значения1 = массив(1, массив(2, 3));
    ЗАДАТЬ табл1 = таблица(ключи1, значения1);

    НАПЕЧАТАТЬ табл1;

    добавить_в_таблицу(табл1, "к31", таблица(ключи1, значения1));
    НАПЕЧАТАТЬ "табл1=";
    НАПЕЧАТАТЬ табл1;
    НАПЕЧАТАТЬ извлечь_из_таблицы(извлечь_из_таблицы(табл1, "к31"), "ключ1");
    НАПЕЧАТАТЬ извлечь_из_таблицы(извлечь_из_таблицы(табл1, "к31"), "ключ2");
    НАПЕЧАТАТЬ извлечь_из_таблицы(табл1, "к31");
    добавить_в_таблицу(извлечь_из_таблицы(табл1, "к31"), "нов_к", 111);
    НАПЕЧАТАТЬ табл1;

    !!func_wa(1,2,3);
    !func_wa(1,2,func_wa(1,5));
    !func_wa(1, 2);

    !func_wa(1,2);


    ВЕРНУТЬ mul(9, mul(mul(3, 1, 2), 5, 4), 8) * mul(9, mul(mul(3, 1, 2), 5, 4), 8);
)

