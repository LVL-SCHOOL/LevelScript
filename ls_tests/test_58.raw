ВКЛЮЧИТЬ стандартная_библиотека._.test_lib
ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ проц3(проц) (
    проц(1);
)

ОПРЕДЕЛИТЬ КЛАСС Тестовый (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) () (
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) мет (проц) (
        проц3(проц);
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ проц2(проц) (
    ЗАДАТЬ т = Тестовый();

    т:мет(проц);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ проц(арг) (
    НАПЕЧАТАТЬ арг;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ с = временная_метка();
    проц2(проц);
    НАПЕЧАТАТЬ временная_метка() - с;

    КОНТЕКСТ (
        КОНТЕКСТ (
            достать_из_массива(массив(1, 2), 100);
        )
        ОБРАБОТЧИК ОшибкаДелениеНаНоль КАК _ (
            НАПЕЧАТАТЬ "Деление на ноль!";
        )
    )
    ОБРАБОТЧИК БазоваяОшибка КАК _ (
            НАПЕЧАТАТЬ "Базовая ошибка";
    )

    !НАПЕЧАТАТЬ старт НЕ РАВНО 1;
)

ВЫПОЛНИТЬ (
    старт();
)
