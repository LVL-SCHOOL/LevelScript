ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(номер) (
    БЛОКИРОВАТЬ (
        ЦИКЛ ОТ 1 ДО 10  (
            НАПЕЧАТАТЬ форматировать_строку("Привет из: {}", номер)
        )
    )
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная(аргументы...) (
    ЗАДАТЬ планировщик;планировщик = ПланировщикЗадач();;ОТЛОЖИТЬ планировщик:результаты();ЦИКЛ счет ОТ 1 ДО 10 (
        планировщик:добавить(В ФОНЕ фон(счет))
    )

    !1 / 0
)

ВЫПОЛНИТЬ (
    главная()
)
