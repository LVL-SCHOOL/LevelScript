ВКЛЮЧИТЬ стандартная_библиотека.конкурентность
ВКЛЮЧИТЬ стандартная_библиотека.время
ВКЛЮЧИТЬ стандартная_библиотека.строки
ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ задача_с_блокировкой(номер, блокировщик, начало) (
    блокировщик:блокировать();
    ЖДАТЬ В ФОНЕ асинхронный_сон(0.1);ЗАДАТЬ прошло = временная_метка() - начало;НАПЕЧАТАТЬ форматировать_строку("Задача №{} вышла из блокировки. Прошло: {} сек.", номер, прошло);
    блокировщик:отпустить();
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ задача_с_блокировкой2(номер, блокировщик, начало) (

   блокировщик:блокировать()
    ЖДАТЬ В ФОНЕ асинхронный_сон(0.1);

    ЗАДАТЬ прошло = временная_метка() - начало;

    НАПЕЧАТАТЬ форматировать_строку("Задача №{} вышла из блокировки. Прошло: {} сек.", номер, прошло);

    блокировщик:отпустить();
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ блокировщик = Блокировщик();
    ЗАДАТЬ начало = временная_метка();
    ЗАДАТЬ планировщик = ПланировщикЗадач();

    ЦИКЛ счет ОТ 1 ДО 5 (
        планировщик:добавить(В ФОНЕ задача_с_блокировкой(счет, блокировщик, начало));
    )

    ЦИКЛ счет ОТ 1 ДО 5 (
        планировщик:добавить(В ФОНЕ задача_с_блокировкой2(счет, блокировщик, начало));
    )

    планировщик:результаты();

    ЗАДАТЬ общее_время = временная_метка() - начало;
    НАПЕЧАТАТЬ форматировать_строку("\nОбщее время: {} сек.", общее_время);
    НАПЕЧАТАТЬ форматировать_строку("Ожидаемое при последовательном выполнении: ~0.5 сек. (5 задач × 0.1 сек.)");
    НАПЕЧАТАТЬ форматировать_строку("Если бы блокировки не было: ~0.1 сек. (все задачи одновременно)");

    ! Проверка
    ЕСЛИ общее_время БОЛЬШЕ 0.4 * 2 ТО (
        НАПЕЧАТАТЬ "\nТЕСТ ПРОЙДЕН: Блокировщик работает глобально! Задачи выполнялись последовательно.";
    )
    ИНАЧЕ (
        НАПЕЧАТАТЬ "\nТЕСТ ПРОВАЛЕН: Блокировщик не блокирует! Задачи выполнились параллельно.";
    )
)


ВЫПОЛНИТЬ (
    главная();
)
