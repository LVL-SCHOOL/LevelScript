ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) () (
        ссылка:поле = 2
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) УМНОЖЕНИЕ (другой) (
        НАПЕЧАТАТЬ 1
        ВЕРНУТЬ ссылка:поле * другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) ДЕЛЕНИЕ (другой) (
        НАПЕЧАТАТЬ 2
        ВЕРНУТЬ ссылка:поле / другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) СЛОЖЕНИЕ (другой) (
        НАПЕЧАТАТЬ 3
        ВЕРНУТЬ ссылка:поле + другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) ВЫЧИТАНИЕ (другой) (
        НАПЕЧАТАТЬ 4
        ВЕРНУТЬ ссылка:поле - другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) СТЕПЕНЬ (другой) (
        НАПЕЧАТАТЬ 5
        ВЕРНУТЬ ссылка:поле ^ другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) И (другой) (
        НАПЕЧАТАТЬ 6
        ВЕРНУТЬ ссылка:поле И другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) ИЛИ (другой) (
        НАПЕЧАТАТЬ 7
        ВЕРНУТЬ ссылка:поле ИЛИ другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) БОЛЬШЕ (другой) (
        НАПЕЧАТАТЬ 8
        ВЕРНУТЬ ссылка:поле БОЛЬШЕ другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) МЕНЬШЕ (другой) (
        НАПЕЧАТАТЬ 9
        ВЕРНУТЬ ссылка:поле МЕНЬШЕ другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) РАВНО (другой) (
        НАПЕЧАТАТЬ 10
        ВЕРНУТЬ ссылка:поле РАВНО другой
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) НЕРАВНО (другой) (
        НАПЕЧАТАТЬ 11
        ВЕРНУТЬ ссылка:поле НЕРАВНО другой
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ тест1 = Тест()
    ЗАДАТЬ тест2 = Тест()

    НАПЕЧАТАТЬ тест1 * 10
    НАПЕЧАТАТЬ тест1 / 10
    НАПЕЧАТАТЬ тест1 + 10
    НАПЕЧАТАТЬ тест1 - 10
    НАПЕЧАТАТЬ тест1 ^ 10
    НАПЕЧАТАТЬ тест1 И 10
    НАПЕЧАТАТЬ тест1 ИЛИ 10
    НАПЕЧАТАТЬ тест1 БОЛЬШЕ 10
    НАПЕЧАТАТЬ тест1 МЕНЬШЕ 10
    НАПЕЧАТАТЬ тест1 РАВНО 10
    НАПЕЧАТАТЬ тест1 НЕРАВНО 10
)

ВЫПОЛНИТЬ (
    главная()
)
