ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(номер) (
    ЦИКЛ ОТ 1 ДО 200  (
        НАПЕЧАТАТЬ форматировать_строку("Привет из: {}", номер)
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _(с) (
    НАПЕЧАТАТЬ точная_временная_метка() - с
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест() (
    ЗАДАТЬ ф = В ФОНЕ фон(1)
    спать(0.6)
    ЗАДАТЬ с = точная_временная_метка()
    _(с)
    ЖДАТЬ ф

)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная(аргументы...) (
    ЗАДАТЬ планировщик;планировщик = ПланировщикЗадач();;ОТЛОЖИТЬ планировщик:результаты();ЦИКЛ счет ОТ 1 ДО 200 (
        планировщик:добавить(В ФОНЕ фон(счет))
    )

    !1 / 0
)

ВЫПОЛНИТЬ (
    !главная()
    тест()
)
