ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (
    ЖДАТЬ В ФОНЕ асинхронный_сон(1);
    НАПЕЧАТАТЬ "пока!";
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сон(мас) (
    НАПЕЧАТАТЬ "Сон...";
    ЖДАТЬ В ФОНЕ асинхронный_сон(достать_из_массива(мас,0-0));
    НАПЕЧАТАТЬ "Проснулся";
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон2(аргументы) (
    ЖДАТЬ В ФОНЕ асинхронный_сон(1);
    НАПЕЧАТАТЬ форматировать_строку("пока из {}", аргументы) ;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ программа() (
    ЗАДАТЬ чел  = 1;
    ОТЛОЖИТЬ вывод("КОНЕЦ ФУНКЦИИ 1!");
    КОНТЕКСТ (
        ОТЛОЖИТЬ вывод("КОНЕЦ ОШИБКИ!");
        1 / 0;
    )
    ОБРАБОТЧИК БазоваяОшибка КАК _ (
        НАПЕЧАТАТЬ "случилось деление на 0";
        ОТЛОЖИТЬ вывод("КОНЕЦ ОБРАБОТЧИКА!");
        !1 / 0;
        ОТЛОЖИТЬ вывод(ЖДАТЬ В ФОНЕ асинхронный_сон(0.1));
        ОТЛОЖИТЬ В ФОНЕ асинхронный_сон(1);
        ОТЛОЖИТЬ В ФОНЕ асинхронный_сон(1);
        ОТЛОЖИТЬ В ФОНЕ асинхронный_сон(1);
    )
    НАПЕЧАТАТЬ чел РАВЕН 1;
    НАПЕЧАТАТЬ чел РАВНЫ 1;
    НАПЕЧАТАТЬ НЕ ИСТИНА;
    ОТЛОЖИТЬ вывод("КОНЕЦ ФУНКЦИИ 2!");
    НАПЕЧАТАТЬ "РАВНЫ";
    НАПЕЧАТАТЬ "чел РАВНЫ 1";
    НАПЕЧАТАТЬ массив("чел РАВНЫ 1", чел РАВНЫ 1, "РАВНЫ");
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ отложенный_запуск = ОтложенныйЗапуск();
    ОТЛОЖЕННО отложенный_запуск:запуск();

    ЦИКЛ ОТ 1 ДО 5 (
        отложенный_запуск:добавить(фон2, массив(1));
    )

    ЦИКЛ ОТ 1 ДО 5 (
        отложенный_запуск:добавить(фон);
    )

    ЦИКЛ ОТ 1 ДО 50 (
        отложенный_запуск:добавить(сон, массив(1));
    )

    !ОТЛОЖЕННО ЖДАТЬ В ФОНЕ фон();

    ОТЛОЖИТЬ вывод("КОНЕЦ ПРОГРАММЫ!");
    ЕСЛИ ИСТИНА ТО (
        ОТЛОЖИТЬ вывод("КОНЕЦ ОВ!");

        ЦИКЛ счет ОТ 1 ДО 100 (
            НАПЕЧАТАТЬ массив((счет + 2) * 2) * 2;
        )
    )
    программа();

    ОТЛОЖИТЬ вывод("КОНЕЦ ПРОГРАММЫ2!");
    ОТЛОЖИТЬ вывод(ждать_всех(массив()));
)

ВЫПОЛНИТЬ (
    старт();
)
