ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) () (
        ссылка:поле = 2
    )
    ОПРЕДЕЛИТЬ ПОВЕДЕНИЕ (ссылка) СЛОЖЕНИЕ (другой) (
        ВЕРНУТЬ ссылка:поле + другой
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ тест1 = Тест()
    ЗАДАТЬ старт

    старт = временная_метка()

    ЦИКЛ ОТ 1 ДО 100 (
        тест1 + 10
    )

    НАПЕЧАТАТЬ временная_метка() - старт

    старт = временная_метка()

    ЦИКЛ ОТ 1 ДО 100 (
        2 + 10
    )

    НАПЕЧАТАТЬ временная_метка() - старт
)


ВЫПОЛНИТЬ (
    главная()
)
