ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ test () (
в_логический((10 + 10) * 0)
    1 + 1; 2 + 2;

    !КОНТЕКСТ (
        ЗАДАТЬ н = 1; 1 + 1; 2+ 2; 1 /н; 4 + 1; н = 1000; н = 0; 1 /1;  !ОТЛОЖИТЬ 1 /0; ! ;;;;;;;;;;;; НАПЕЧАТАТЬ 2123123; ЗАДАТЬ н = 1;
   !)
    !ОБРАБОТЧИК БазоваяОшибка КАК _ (
    !)

    НАПЕЧАТАТЬ "ПРИВЕТ!УЦЦУ";!;


    НАПЕЧАТАТЬ 2 + 2 * 2

    1 + 1; ! комментарий; 1 + 1
    НАПЕЧАТАТЬ "строка с ; внутри"; НАПЕЧАТАТЬ 115
НАПЕЧАТАТЬ 1; НАПЕЧАТАТЬ 2; НАПЕЧАТАТЬ 1 /1;НАПЕЧАТАТЬ 1 + 1; ! 1+ 2
    !НАПЕЧАТАТЬ 1; НАПЕЧАТАТЬ 2;НАПЕЧАТАТЬ 2 /1; ВЕРНУТЬ; НАПЕЧАТАТЬ 1 / 0

    НАПЕЧАТАТЬ 2 + 2 * 2
)

ВЫПОЛНИТЬ (
    test()
    вывод(в_логический((10 + 10) * 0))
)
