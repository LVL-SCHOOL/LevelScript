ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача(номер) (
    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, делает запрос в интернет", номер);
    ЗАДАТЬ результат = запрос_в_интернет("GET", "https://ya.ru", таблица());
    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, выполнена! Статус: {}", номер, извлечь_из_таблицы(результат, "статус_код"));
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача3(номер) (
    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, делает спит", номер);

    ЖДАТЬ В ФОНЕ спать(1);

    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, выполнена!", номер);

)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача2(номер) (
    ЦИКЛ счет ОТ 1 ДО 1000 (
        НАПЕЧАТАТЬ "привет номер " + в_строку(счет) + " от " + в_строку(номер)
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ задачи = Список()

    ЦИКЛ счет ОТ 1 ДО 100 (
      ! В ФОНЕ фоновая_задача2(счет)
      ! В ФОНЕ массив(счет)
    )

   ! НАПЕЧАТАТЬ ЖДАТЬ В ФОНЕ массив(ЖДАТЬ В ФОНЕ массив(1,2,3))

    ЦИКЛ счет ОТ 1 ДО 10 (
       ! В ФОНЕ запрос_в_интернет("GET", "https://ya.ru", таблица());
      ! В ФОНЕ массив();
     !   задачи:добавить(В ФОНЕ массив());
      !  задачи:добавить(В ФОНЕ фоновая_задача(счет));
       ! задачи:добавить(В ФОНЕ запрос_в_интернет("GET", "https://ya.ru", таблица(), таблица(), таблица()));
       ! задачи:добавить(В ФОНЕ запрос_в_интернет("GET", "http://127.0.0.1:5050", таблица()));
       ! запрос_в_интернет("GET", "http://127.0.0.1:5050", таблица());
       ! запрос_в_интернет("GET", "https://ya.ru", таблица());
       !задачи:добавить(В ФОНЕ запрос_в_интернет("GET", "https://httpbin.org/delay/0.1", таблица()));
      !  задачи:добавить(В ФОНЕ спать(1));
       ! задачи:добавить(В ФОНЕ фоновая_задача3(счет));
       задачи:добавить(В ФОНЕ массив(счет));
       ! задачи:добавить(В ФОНЕ массив(ЖДАТЬ В ФОНЕ массив(1,2,3)));
    )

    НАПЕЧАТАТЬ задачи:в_массив()

    ПОКА длина_массива(получить_все_задачи()) (
        НАПЕЧАТАТЬ длина_массива(получить_все_задачи())
        спать(1)
    )

   ждать_всех(задачи:в_массив())
   ! НАПЕЧАТАТЬ ждать_всех(получить_все_задачи())
)

ВЫПОЛНИТЬ (
    главная()
)
