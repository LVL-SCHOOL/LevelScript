ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Сортировщик (
    ОПРЕДЕЛИТЬ МЕТОД (ссылка) сортировка_массива() (
        ЗАДАТЬ длина = длина_массива(ссылка:массив_чисел)
        ЗАДАТЬ минимальный_индекс = 0

        ЦИКЛ индекс ОТ 0 ДО длина-1 (
            ! Находим минимальный элемент в оставшейся части массива
            минимальный_индекс = индекс

            ЦИКЛ внутренний_индекс ОТ индекс+1 ДО длина-1 (
                ЕСЛИ достать_из_массива(ссылка:массив_чисел, внутренний_индекс) МЕНЬШЕ достать_из_массива(ссылка:массив_чисел, минимальный_индекс) ТО (
                    минимальный_индекс = внутренний_индекс
                )
            )

            ! Меняем местами найденный минимальный элемент с текущим
            ЕСЛИ минимальный_индекс НЕРАВНО индекс ТО (
                ЗАДАТЬ временная_переменная = достать_из_массива(ссылка:массив_чисел, индекс)

                изменить_в_массиве(
                    ссылка:массив_чисел, индекс,
                    достать_из_массива(ссылка:массив_чисел, минимальный_индекс),
                )
                изменить_в_массиве(
                    ссылка:массив_чисел, минимальный_индекс, временная_переменная,
                )
            )
        )

        ВЕРНУТЬ ссылка:массив_чисел
   )
)

ОПРЕДЕЛИТЬ КЛАСС ДоставщикДанных НАСЛЕДОВАТЬ ОТ Сортировщик (
    ОПРЕДЕЛИТЬ МЕТОД (ссылка) установить_массив(массив_чисел...) (
        ссылка:массив_чисел = массив_чисел
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт (аргументы...) (
    ЗАДАТЬ сортировка = ДоставщикДанных()

    НАПЕЧАТАТЬ сортировать_массив(
        массив(
            -45.2, 0.5, 789, -3.14, 22.75, -101, 8.8, 0, -0.1, 66.66, 45, -32.01, 17.3, -90.9, 256, -1.618, 3.0, 44.44,
            -77, 0.125, 19, -55.5, 1024.5, -2.7, 33.33, 6.02, -13, 99.9, -200, 0.75, 512, -8.88, 7.77, -0.001, 314.15,
            60, -42.0, 5.55, -999, 1.5, 27, -18.3, 404, -6.66, 123.456, -50, 0.333, 81, -4.4, 2.718, 10, -76.5, 420.69,
            -30, 16.16, 53, -0.99, 1000, -128, 3.33, 88, -12.12, 74, -500.5, 0.001, 9.81, -2.2, 111, 21.21, -85, 365,
            -7.5, 48.6, -0.05, 69, 300, -111.1, 4.0, -19.9, 25.25, 777, -43, 0.707, 55, -8.0, 92.5, -666, 14.4, 36.6,
            -24, 1.414, -9.99, 112.5, -80.8, 2.0, 70.7, -58.8, 0.123, 63, -34.5, 888.88,
            -45.2, 0.5, 789, -3.14, 22.75, -101, 8.8, 0, -0.1, 66.66, 45, -32.01, 17.3, -90.9, 256, -1.618, 3.0, 44.44,
            -77, 0.125, 19, -55.5, 1024.5, -2.7, 33.33, 6.02, -13, 99.9, -200, 0.75, 512, -8.88, 7.77, -0.001, 314.15,
            60, -42.0, 5.55, -999, 1.5, 27, -18.3, 404, -6.66, 123.456, -50, 0.333, 81, -4.4, 2.718, 10, -76.5, 420.69,
            -30, 16.16, 53, -0.99, 1000, -128, 3.33, 88, -12.12, 74, -500.5, 0.001, 9.81, -2.2, 111, 21.21, -85, 365,
            -7.5, 48.6, -0.05, 69, 300, -111.1, 4.0, -19.9, 25.25, 777, -43, 0.707, 55, -8.0, 92.5, -666, 14.4, 36.6,
            -24, 1.414, -9.99, 112.5, -80.8, 2.0, 70.7, -58.8, 0.123, 63, -34.5, 888.88,
        )
