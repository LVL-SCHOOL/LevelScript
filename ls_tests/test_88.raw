ВКЛЮЧИТЬ стандартная_библиотека.*
ВКЛЮЧИТЬ стандартная_библиотека.строки
ВКЛЮЧИТЬ стандартная_библиотека.ввод_вывод
ВКЛЮЧИТЬ стандартная_библиотека.математика


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест(func_x, func_y, func_z) (
            ЗАДАТЬ x = 2
    ЦИКЛ loop_i ОТ 1 ДО 5 (
        КОНТЕКСТ (
            ЗАДАТЬ x = 2
        )
        ОБРАБОТЧИК ОшибкаНеопределенногоИмени КАК _ (
            КОНТЕКСТ (
                !Тут намеренная ошибка синтаксиса
                НАПЕЧАТАТЬ "ОбъектнаяОшибка 1", x
            )
            ОБРАБОТЧИК ОшибкаСинтаксиса КАК _ (
                НАПЕЧАТАТЬ "СинтаксическаяОшибка 2"
            )
        )
        НАПЕЧАТАТЬ форматировать_строку("Привет! {} {}", x, loop_i)

        НАПЕЧАТАТЬ форматировать_строку("x: {} y: {} z: {}", func_x, func_y, func_z)
    )

    НАПЕЧАТАТЬ "КОНЕЦ_ЦИКЛА"

    КОНТЕКСТ (
        НАПЕЧАТАТЬ loop_i
    )
    ОБРАБОТЧИК ОшибкаНеопределенногоИмени КАК _ (
        НАПЕЧАТАТЬ "ОбъектнаяОшибка 3"
    )

    НАПЕЧАТАТЬ "КОНЕЦ_ПОПЫТКИ1"

    НАПЕЧАТАТЬ форматировать_строку("x: {} y: {} z: {} КОНЕЦ", func_x, func_y, func_z)
    НАПЕЧАТАТЬ "КОНЕЦ ПРОЦЕДУРЫ"
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная(func_x, func_y, func_z) (

    ЗАДАТЬ начало = временная_метка()

    ! Определение массива
    ЗАДАТЬ arr = массив(1, 2, 3, 4)
    ! 0 1 2 3

    КОНТЕКСТ (
        НАПЕЧАТАТЬ достать_из_массива(arr, 0)
        НАПЕЧАТАТЬ достать_из_массива(arr, 1)
        НАПЕЧАТАТЬ достать_из_массива(arr, 2)
        НАПЕЧАТАТЬ достать_из_массива(arr, 3)
        НАПЕЧАТАТЬ достать_из_массива(arr, 4)
    )
    ОБРАБОТЧИК ОшибкаИндекса КАК _ (
        НАПЕЧАТАТЬ "ИндекснаяОшибка!!!"
    )

    тест(1, 2, 3)

    КОНТЕКСТ (
        НАПЕЧАТАТЬ "тест"

        ! Ошибка, попытка переопределить переменную
        ЗАДАТЬ x = 2
    )
    ОБРАБОТЧИК ОшибкаНеопределенногоИмени КАК _ (
        КОНТЕКСТ (
            НАПЕЧАТАТЬ "ОбъектнаяОшибка 4", x
        )
        ОБРАБОТЧИК ОшибкаСинтаксиса КАК _ (
            НАПЕЧАТАТЬ "СинтаксическаяОшибка 5"
        )
    )

    НАПЕЧАТАТЬ "КОНЕЦ_ПОПЫТКИ2"

    КОНТЕКСТ (
        КОНТЕКСТ (
            ! Ошибка, обращение к неизвестной переменной
            НАПЕЧАТАТЬ loop_i
        )
        ОБРАБОТЧИК ОшибкаНеопределенногоИмени КАК _ (
            НАПЕЧАТАТЬ "ОбъектнаяОшибка 6"
        )
    )
    ОБРАБОТЧИК ОшибкаНеопределенногоИмени КАК _ (
        НАПЕЧАТАТЬ "ОбъектнаяОшибка 7"
    )

    НАПЕЧАТАТЬ "тест 2"

    тест(1, 2, 3)

    ЦИКЛ _ ОТ 1 ДО 20 (
        НАПЕЧАТАТЬ "ФИНАЛЬНЫЙ_ЦИКЛ"
    )

    НАПЕЧАТАТЬ временная_метка() - начало

)

ВЫПОЛНИТЬ (
    главная(1, 2, 3)
)

