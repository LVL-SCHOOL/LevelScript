
ВКЛЮЧИТЬ стандартная_библиотека.*



ОПРЕДЕЛИТЬ ПРОЦЕДУРУ func(a)(
    ЕСЛИ ИСТИНА ТО (
        НАПЕЧАТАТЬ "ЕСЛИ ИСТИНА ТО_1";
    )
    ЕСЛИ ЛОЖЬ ТО (
        НАПЕЧАТАТЬ "ЕСЛИ ЛОЖЬ ТО_1";
    )
    ИНАЧЕ ЕСЛИ ИСТИНА ТО (
        НАПЕЧАТАТЬ "ИНАЧЕ ЕСЛИ ИСТИНА ТО";
        ЕСЛИ ЛОЖЬ ТО (
            НАПЕЧАТАТЬ "ЕСЛИ ЛОЖЬ ТО_2";
        )
        ИНАЧЕ (
            НАПЕЧАТАТЬ "wrapИНАЧЕ";
        )
        НАПЕЧАТАТЬ "ИНАЧЕ ЕСЛИ ИСТИНА ТО кон.....";
    )
    ИНАЧЕ (
        НАПЕЧАТАТЬ "ИНАЧЕ";
    )

    ВЕРНУТЬ 1;
)

ВЫПОЛНИТЬ (
    func(1);
    func(2);
    func(3);
    func(4);
)


ВЫПОЛНИТЬ (
    func(1);
    func(2);
    func(3);
    func(4);
)
