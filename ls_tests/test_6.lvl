
ВКЛЮЧИТЬ стандартная_библиотека.*



ОПРЕДЕЛИТЬ ПРОЦЕДУРУ ошибка()(
    НАПЕЧАТАТЬ "ПРИВ";
    ВЕРНУТЬ   5;
)
ОПРЕДЕЛИТЬ ПРОЦЕДУРУ процедура(номер_процедуры)(
 !1/ 0;
    ЗАДАТЬ задача = В ФОНЕ ошибка();
    ! НАПЕЧАТАТЬ 1/ 0;

    ЦИКЛ счет ОТ 1 ДО ЖДАТЬ задача (
        НАПЕЧАТАТЬ форматировать_строку("Привет из процедуры номер: {} итерация номер {}", номер_процедуры, счет);
    )

    ВЕРНУТЬ 212;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ по_умолчанию()(
    НАПЕЧАТАТЬ "по_умолчанию" * 10;
    ВЕРНУТЬ 100;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ аргументы_по_умолчанию(а=3, c=1, б=массив(1, массив(2, 3)), q=2, f=массив(2+2*2, (2+2)*2), bool=ИСТИНА ИЛИ ИСТИНА И (ЛОЖЬ), _=по_умолчанию())(
    ! НАПЕЧАТАТЬ форматировать_строку("a={} б={} , c={} q={} f={}, bool={} _={}", а, б, c, q, f, bool, _);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сонный_чел(номер_процедуры)(
    НАПЕЧАТАТЬ "я спать! " + в_строку(номер_процедуры);
    ЖДАТЬ В ФОНЕ асинхронный_сон(1);
    НАПЕЧАТАТЬ "доброе утро! " + в_строку(номер_процедуры);
    ВЕРНУТЬ 100;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ матан(номер_процедуры)(
    НАПЕЧАТАТЬ (2 + 2) * 2;
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ func(a)(
    НАПЕЧАТАТЬ 0.1 + 0.4;
    ЖДАТЬ В ФОНЕ матан(1);
    ЖДАТЬ В ФОНЕ асинхронный_сон(0.2);
    ! спать(2);
    ЗАДАТЬ задачи = массив();

    ЗАДАТЬ старт = временная_метка();
    ЦИКЛ номер_процедуры ОТ 0 ДО 100 (
        ! матан(номер_процедуры);
        добавить_в_массив(задачи, В ФОНЕ сонный_чел(номер_процедуры));
    )

   ЦИКЛ ОТ 0 ДО 1000 (
        НАПЕЧАТАТЬ "ПРИВЕТ ЧЕЛЫ)))";
   )

    ЗАДАТЬ задача = 0;

    ЦИКЛ индекс ОТ 0 ДО длина_массива(задачи) -1 (
      задача = достать_из_массива(задачи, индекс);
      НАПЕЧАТАТЬ задача;
      ЦИКЛ шаг ОТ 0 ДО ЖДАТЬ задача (
        НАПЕЧАТАТЬ форматировать_строку("задача={} шаг={}", задача, шаг);
      )
    )

    НАПЕЧАТАТЬ временная_метка() - старт;

    ЕСЛИ ЛОЖЬ ТО (
        НАПЕЧАТАТЬ "ЕСЛИ1";
    )
    ИНАЧЕ ЕСЛИ ЛОЖЬ ТО (
        НАПЕЧАТАТЬ "ИЕ1";
    )
    ИНАЧЕ ЕСЛИ ИСТИНА ТО (
        НАПЕЧАТАТЬ "ИЕ2";
    )
    ИНАЧЕ (
        НАПЕЧАТАТЬ "ИНАЧЕ1";
    )

    ВЕРНУТЬ 1;
)


ВЫПОЛНИТЬ (
func(1)
)