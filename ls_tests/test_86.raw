ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС ОшибкаАргументов НАСЛЕДОВАТЬ ОТ БазоваяОшибка (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) (инфа="Вы передали в функцию неверное количество аргументов") (
        ссылка:информация = инфа
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(аргументы...) (
    ЗАДАТЬ ранд
    ЗАДАТЬ счет

    ЕСЛИ длина_массива(аргументы) РАВНА 1 ТО (
        ранд = достать_из_массива(аргументы, 0)
        счет = -1
    )
    ИНАЧЕ ЕСЛИ длина_массива(аргументы) РАВНА 2 ТО (
        ранд = достать_из_массива(аргументы, 0)
        счет = достать_из_массива(аргументы, 1)
    )
    ИНАЧЕ (
        ОШИБКА ОшибкаАргументов()
    )

    НАПЕЧАТАТЬ "Привет из процедуры номер: " + в_строку(счет)

    ЕСЛИ ранд:бросить_монетку() ТО (
        спать(1)
    )
    ИНАЧЕ (
        ЖДАТЬ В ФОНЕ асинхронный_сон(1)
    )

    НАПЕЧАТАТЬ "Пока из процедуры номер: " + в_строку(счет)
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест() (
    ЗАДАТЬ ранд = ГенераторСлучайныхЧисел()
    ЗАДАТЬ планировщик = ПланировщикЗадач()

    ЦИКЛ счет ОТ 1 ДО 100 (
        планировщик:добавить(В ФОНЕ фон(ранд, счет))
    )

    планировщик:результаты()
)

ВЫПОЛНИТЬ (
    тест()
)
