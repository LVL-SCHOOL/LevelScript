ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(ранд, счет) (
    ЕСЛИ ранд:бросить_монетку() ТО (
        спать(1)
    )
    ИНАЧЕ (
        ЖДАТЬ В ФОНЕ асинхронный_сон(1)
    )

    НАПЕЧАТАТЬ "привет) из " + в_строку(счет)
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест() (
    ЗАДАТЬ ранд = ГенераторСлучайныхЧисел()
    ЗАДАТЬ планировщик = ПланировщикЗадач()

    ЦИКЛ счет ОТ 1 ДО 100 (
        планировщик:добавить(В ФОНЕ фон(ранд, счет))
    )

    планировщик:результаты()
)

ВЫПОЛНИТЬ (
    тест()
)
