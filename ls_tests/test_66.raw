ВКЛЮЧИТЬ стандартная_библиотека.*

ОПРЕДЕЛИТЬ КЛАСС Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (_) () (
    _:ТЕСТ = 1;
            !ВЕРНУТЬ 1 + 1;
        ЕСЛИ ИСТИНА ТО (
         !   ВЕРНУТЬ 1 + 1;
        )
        ИНАЧЕ (

                        ВЕРНУТЬ;
        )

        ЦИКЛ ОТ 1 ДО 100 (
            КОНТЕКСТ (
                ЕСЛИ ЛОЖЬ ТО (
                    ПОКА ИСТИНА (
                        ВЕРНУТЬ;
                    )
                )
            )
            ОБРАБОТЧИК БазоваяОшибка КАК _ (
                        ВЕРНУТЬ;
            )
        )
    )
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ список = Список();

    ОТЛОЖИТЬ вывод(ждать_всех(список:в_массив()));

    ЦИКЛ ОТ 1 ДО 10 (
        список:добавить(В ФОНЕ асинхронный_сон(1));
    )

    ЗАДАТЬ т = Тест();

    НАПЕЧАТАТЬ т:ТЕСТ;

    ВЕРНУТЬ;
)

ВЫПОЛНИТЬ (
    старт();
    показать_узлы_сущности(старт);
)