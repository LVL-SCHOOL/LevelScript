ВКЛЮЧИТЬ стандартная_библиотека._.test_lib
ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
 _test_extend_proc_signature("arg", 1, ИСТИНА, массив(), таблица(), старт);
 КОНТЕКСТ (
     _test_extend_proc_signature(-1, 1, ИСТИНА, массив(), таблица(), старт);
 )
 ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
     )
  КОНТЕКСТ (
 _test_extend_proc_signature("arg", "", ИСТИНА, массив(), таблица(), старт);
 )
  ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
     )


 КОНТЕКСТ (
     _test_extend_proc_signature("arg", 1, "ИСТИНА", массив(), таблица(), старт);
 )
 ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
)

 КОНТЕКСТ (
 _test_extend_proc_signature("arg", 1, ИСТИНА, "массив()", таблица(), старт);
)
 ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
)
КОНТЕКСТ (
    _test_extend_proc_signature("arg", 1, ИСТИНА, массив(), "таблица()", старт);
)
ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
)
КОНТЕКСТ (
    _test_extend_proc_signature("arg", 1, ИСТИНА, массив(), таблица(), 1);
)
ОБРАБОТЧИК ОшибкаТипа КАК _ (
    НАПЕЧАТАТЬ _:информация;
)

)
ВЫПОЛНИТЬ (
    старт();
)
