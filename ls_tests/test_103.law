ВКЛЮЧИТЬ стандартная_библиотека.*

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ ф() (
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
   ЗАДАТЬ задачи = Список()

    ЦИКЛ счет ОТ 1 ДО 10 (
        НАПЕЧАТАТЬ форматировать_строку("Запуск слипа номер {}", счет)
        задачи:добавить(В ФОНЕ асинхронный_сон(0.1))
        В ФОНЕ ф()
        В ФОНЕ асинхронный_сон(0.1)
    )

    НАПЕЧАТАТЬ получить_все_задачи()
    ждать_всех(получить_все_задачи())

)


ВЫПОЛНИТЬ (
    главная()
)
