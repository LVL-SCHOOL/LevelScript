ВКЛЮЧИТЬ стандартная_библиотека.*

!ОПРЕДЕЛИТЬ КЛАСС Тест НАСЛЕДОВАТЬ ОТ рис (
!)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ окно = _создать_окно(1, 1);
    ЗАДАТЬ проц =  окно:проц;
    ЗАДАТЬ число =  115;

    КОНТЕКСТ (
        фыв;
        проц();
        1 / 0;
    )
    ОБРАБОТЧИК ОшибкаДелениеНаНоль КАК _ (
        НАПЕЧАТАТЬ ОшибкаДелениеНаНоль;
    )
    ОБРАБОТЧИК ОшибкаТипа КАК _ (
        НАПЕЧАТАТЬ ОшибкаТипа;
    )
    ОБРАБОТЧИК БазоваяОшибка КАК _ (
        НАПЕЧАТАТЬ БазоваяОшибка;
    )

    НАПЕЧАТАТЬ модуль(200) + число + 22 РАВНО 337.0;

    ЕСЛИ модуль(200) + число + 22 РАВНО 337.0 ТО (
        ЗАДАТЬ множитель = 222;
        НАПЕЧАТАТЬ модуль(200) + число * множитель + 22;
    )
    !НАПЕЧАТАТЬ множитель;
    !удалить_из_массива(массив(), "");
    !удалить_из_массива(массив, 1);
    НАПЕЧАТАТЬ показать_узлы_сущности(старт);
)

ВЫПОЛНИТЬ (
    старт();
)
