ВКЛЮЧИТЬ стандартная_библиотека.интернет
ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ быстрая_сортировка(массив_для_сортировки, низ, верх) (
    ЕСЛИ низ МЕНЬШЕ верх ТО (
        ЗАДАТЬ опорный_индекс = разделить(
            массив_для_сортировки,
            низ,
            верх,
        );
        быстрая_сортировка(
            массив_для_сортировки,
            низ,
            опорный_индекс - 1,
        );
        быстрая_сортировка(
            массив_для_сортировки,
            опорный_индекс + 1,
            верх,
        );
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ разделить(массив_для_сортировки, низ, верх) (
    ЗАДАТЬ опорный_элемент = достать_из_массива(
        массив_для_сортировки,
        верх,
    );
    ЗАДАТЬ i = низ - 1;

    ЦИКЛ j ОТ низ ДО верх - 1 (
        ЕСЛИ достать_из_массива(массив_для_сортировки, j) МЕНЬШЕ опорный_элемент ТО (
            i = i + 1;
            ЗАДАТЬ временный = достать_из_массива(
                массив_для_сортировки,
                i,
            );
            ЗАДАТЬ значение_j = достать_из_массива(
                массив_для_сортировки,
                j,
            );
            изменить_в_массиве(
                массив_для_сортировки,
                i,
                значение_j,
            );
            изменить_в_массиве(
                массив_для_сортировки,
                j,
                временный,
            );
        )
    )

    ЗАДАТЬ временный = достать_из_массива(
        массив_для_сортировки,
        i + 1,
    );
    ЗАДАТЬ значение_верх = достать_из_массива(
        массив_для_сортировки,
        верх,
    );
    изменить_в_массиве(
        массив_для_сортировки,
        i + 1,
        значение_верх,
    );
    изменить_в_массиве(
        массив_для_сортировки,
        верх,
        временный,
    );

    ВЕРНУТЬ i + 1;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ отсортировать(массив_для_сортировки) (
    быстрая_сортировка(
        массив_для_сортировки,
        0,
        длина_массива(массив_для_сортировки) - 1,
    );
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ обработчик_тест(маршрут, запрос) (
    ЗАДАТЬ тело = (
        "<html>" +
        "<head><title>HTTP сервер</title></head>" +
        "<body>" +
        "<h1>ВСЕМ ПРИВЕТ!</h1>" +
        "</body>" +
        "</html>",
    )
    ЗАДАТЬ ключи_заголовков = массив(
        "Content-type",
    )
    ЗАДАТЬ значения_заголовков = массив(
        "text/html; charset=utf-8",
    )
    ЗАДАТЬ заголовки = таблица(ключи_заголовков, значения_заголовков)

    ВЕРНУТЬ Ответ(
        тело,
        заголовки,
        200
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ аборт(запрос) (
    !прервать_обработку(запрос)
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ обработчик_тест_POST(маршрут, запрос) (
    НАПЕЧАТАТЬ запрос

    ЗАДАТЬ тело = (
        "<html>" +
        "<head><title>HTTP сервер</title></head>" +
        "<body>" +
        "<h1>ВСЕМ ПРИВЕТ от POST!</h1>" +
        "</body>" +
        "</html>",
    )
    ЗАДАТЬ ключи_заголовков = массив(
        "Content-type",
    )
    ЗАДАТЬ значения_заголовков = массив(
        "text/html; charset=utf-8",
    )
    ЗАДАТЬ заголовки = таблица(ключи_заголовков, значения_заголовков)

    ВЕРНУТЬ Ответ(
        тело,
        заголовки,
        200
    )
)


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон(номер) (
    ЗАДАТЬ числа

    ПОКА ИСТИНА (
        числа = массив(
            64,
            34,
            25,
            12,
            22,
            11,
            90,
            5,
        );

        НАПЕЧАТАТЬ форматировать_строку(
            "До сортировки: \n{}",
            числа,
        )

        отсортировать(числа);

        НАПЕЧАТАТЬ форматировать_строку(
            "После сортировки: \n{}",
            числа,
        )
        НАПЕЧАТАТЬ "привет из фон номер " + в_строку(номер)
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон2(номер) (

    ПОКА ИСТИНА (
        НАПЕЧАТАТЬ "привет из фон2 номер " + в_строку(номер)
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фоновая_задача(номер) (
    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, делает запрос в интернет", номер);
    ЗАДАТЬ результат = запрос_в_интернет("GET", "https://ya.ru", таблица());
    НАПЕЧАТАТЬ форматировать_строку("Задача номер {}, выполнена! Статус: {}", номер, извлечь_из_таблицы(результат, "статус_код"));
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЦИКЛ счет ОТ 1 ДО 1000 (
       !В ФОНЕ фон(счет)
      ! В ФОНЕ фон2(счет)
       !В ФОНЕ асинхронный_сон(10)
      ! В ФОНЕ фоновая_задача(счет)
    )

    ЗАДАТЬ обработчик = Обработчик()
    обработчик:добавить_GET_маршрут("/test", обработчик_тест)
    обработчик:добавить_POST_маршрут("/test", обработчик_тест_POST)
    обработчик:добавить_промежуточный_обработчик(аборт)

    ЗАДАТЬ сервер = Сервер("localhost", 5050, обработчик)

   ! ЗАДАТЬ запуск_фон = В ФОНЕ сервер:запуск()
   ! ЖДАТЬ запуск_фон

   сервер :запуск()
   ! спать(1)
)

ВЫПОЛНИТЬ (
   ! главная()
)
