ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ мат() (
    ЦИКЛ ОТ 1 ДО 1000 (
        2 + 2 * 2;
    )

    !НАПЕЧАТАТЬ "готово";
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ запуск_программы() (
    КОНТЕКСТ (
        !ПРЕРВАТЬ;
    )
    ОБРАБОТЧИК БазоваяОшибка КАК _(
        !ПРЕРВАТЬ;
        !ПРОПУСТИТЬ;
    )

    ЗАДАТЬ a1 = В ФОНЕ мат();
    ЗАДАТЬ a2 = В ФОНЕ мат();
    ЗАДАТЬ a3 = В ФОНЕ мат();
    ЗАДАТЬ a4 = В ФОНЕ мат();
    ЗАДАТЬ a5 = В ФОНЕ мат();
    ЗАДАТЬ a6 = В ФОНЕ мат();
    ЗАДАТЬ a7 = В ФОНЕ мат();
    ЗАДАТЬ a8 = В ФОНЕ мат();
    ЗАДАТЬ a9 = В ФОНЕ мат();
    ЗАДАТЬ a10 = В ФОНЕ мат();
    ЗАДАТЬ a11 = В ФОНЕ мат();
    ЗАДАТЬ a12 = В ФОНЕ мат();
    ЗАДАТЬ a13 = В ФОНЕ мат();
    ЗАДАТЬ a14 = В ФОНЕ мат();
    ЗАДАТЬ a15 = В ФОНЕ мат();


    ЖДАТЬ a1;
    ЖДАТЬ a2;
    ЖДАТЬ a3;
    ЖДАТЬ a4;
    ЖДАТЬ a5;
    ЖДАТЬ a6;
    ЖДАТЬ a7;
    ЖДАТЬ a8;
    ЖДАТЬ a9;
    ЖДАТЬ a10;
    ЖДАТЬ a11;
    ЖДАТЬ a12;
    ЖДАТЬ a13;
    ЖДАТЬ a14;
    ЖДАТЬ a15;

    ЕСЛИ ИСТИНА ТО (
        !ПРЕРВАТЬ;
    )
    ИНАЧЕ ЕСЛИ ИСТИНА ТО (
        !ПРЕРВАТЬ;
    )
    ИНАЧЕ (
        !ПРЕРВАТЬ;
    )


)

