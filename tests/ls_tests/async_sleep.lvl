ВКЛЮЧИТЬ стандартная_библиотека.конкурентность
ВКЛЮЧИТЬ стандартная_библиотека.время
ВКЛЮЧИТЬ стандартная_библиотека.строки
ВКЛЮЧИТЬ стандартная_библиотека.структуры.сложные_структуры


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _фон1() (
    ЖДАТЬ В ФОНЕ асинхронный_сон(1)
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _фон2() (
    ЖДАТЬ В ФОНЕ _фон1()
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _фон3() (
    ЖДАТЬ В ФОНЕ _фон2()
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _фон4() (
    ЖДАТЬ В ФОНЕ _фон3()
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ фон() (
    ЖДАТЬ В ФОНЕ _фон4()
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ задачи = ОтложенныйЗапуск();

    ЦИКЛ счет ОТ 1 ДО 100 (
        НАПЕЧАТАТЬ форматировать_строку("Запуск слипа номер {}", счет);
        задачи:добавить(фон);
    )

   задачи:запуск();
   НАПЕЧАТАТЬ "Конец сна!";
)

ВЫПОЛНИТЬ (
    главная();
)
