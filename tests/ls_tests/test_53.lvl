ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Выплаты (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (ссылка) (ученики = массив(), такси = массив(), питание = массив(), часы = 0, цена_за_ученика = 100, цена_за_час = 1100 ) (
        ссылка:ученики = ученики;
        ссылка:такси = такси;
        ссылка:питание = питание;
        ссылка:часы = часы;
        ссылка:_цена_за_ученика = цена_за_ученика;
        ссылка:_цена_за_час = цена_за_час;
    )

    ОПРЕДЕЛИТЬ МЕТОД (ссылка) рассчитать() (
        ВЕРНУТЬ ссылка:часы * ссылка:_цена_за_час + сумма_массива(ссылка:ученики) * ссылка:_цена_за_ученика + сумма_массива(ссылка:такси) + сумма_массива(ссылка:питание);
    )
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ с = временная_метка();
    ЗАДАТЬ часы = 6 * 4 * 2 + 2;
    ЗАДАТЬ выплаты = Выплаты(массив(6, 9, 10, 5, 7, 9, 10, 5, 10, 5, 7, 9, 6, 8, 10, 5, 6, 9, 10, 7, 6, 7, 10, 7), массив(504, 936, 546, 826, 540, 628, 540, 638, 740, 966, 666, 555, 940), массив(600, 600, 600, 600, 600, 600), часы);

    НАПЕЧАТАТЬ выплаты:рассчитать();
    НАПЕЧАТАТЬ временная_метка() - с;

ЗАДАТЬ а = массив(1);
ЗАДАТЬ б = массив(2);
ЗАДАТЬ в = массив(3);
добавить_в_массив(а, б);
добавить_в_массив(б, в);
добавить_в_массив(в, а);

НАПЕЧАТАТЬ а;

)

ВЫПОЛНИТЬ (
    старт();
)
