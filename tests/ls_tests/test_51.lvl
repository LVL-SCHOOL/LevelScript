ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ КЛАСС Тест (
    ОПРЕДЕЛИТЬ КОНСТРУКТОР (_) (арг=длина_массива(массив(2 + 2 * 2, 6, ИСТИНА ИЛИ ЛОЖЬ))) (!"":_ = _();
        НАПЕЧАТАТЬ арг;!"":_ = _();
    )!"":_ = _();
!"":_ = _();
    ОПРЕДЕЛИТЬ МЕТОД (_) метод (арг) (!"":_ = _();
        ЦИКЛ счет ОТ 1 ДО 10 (!"":_ = _();
            НАПЕЧАТАТЬ форматировать_строку("счет={} арг={}", арг, счет);!"":_ = _();
        )!"":_ = _();
    )!"":_ = _();
)!"":_ = _();
!"":_ = _();

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ _() (
    ВЕРНУТЬ 2 + 2 * 2;
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест(мет) (
    ЗАДАТЬ ччч = мет;
    тест2(ччч);
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ тест2(мет) (
    мет(115);
    НАПЕЧАТАТЬ мет;
    НАПЕЧАТАТЬ Тест;
    НАПЕЧАТАТЬ Тест();
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт() (
    ЗАДАТЬ           пер         = Тест          ( )    ;
    ЗАДАТЬ мет = пер:метод;

    тест(мет);

    "":_ = _();
    !"":_ = _();

    НАПЕЧАТАТЬ "":_;
    ЗАДАТЬ СТР = "";

    СТР:_ = _;

    НАПЕЧАТАТЬ пер:метод(2);
    !НАПЕЧАТАТЬ СТР:_();

    НАПЕЧАТАТЬ 1:_ РАВНО ПУСТОТА;
)

ВЫПОЛНИТЬ (
    _();
    старт();
)
