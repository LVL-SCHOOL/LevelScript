ВКЛЮЧИТЬ стандартная_библиотека.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ сонный(счет) (
    НАПЕЧАТАТЬ в_строку(счет) + " начал сон..."
    спать(1)
    НАПЕЧАТАТЬ в_строку(счет) + " поспал"
)

ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЦИКЛ счет ОТ 1 ДО 10 (
        НАПЕЧАТАТЬ форматировать_строку(
            "Запуск слипа номер {}",
            счет,
        ); В ФОНЕ сонный(счет); форматировать_строку( "Запуск слипа номер {}",
            счет,
        ); (2 + 2) * 2;  вывод(
            (
                2
                +
                2
            )
            *
            2
        )
    )

   ! ждать_всех(получить_все_задачи())
)

ВЫПОЛНИТЬ (
    главная()
)
