ВКЛЮЧИТЬ стандартная_библиотека.структуры.*


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ старт (аргументы...) (
    НАПЕЧАТАТЬ аргументы
)

ВЫПОЛНИТЬ (
    старт()
    старт(1)
    старт(1, 2)
    старт(1, 2, 3, 4, 5)

    старт(
        таблица(
            массив(
                "имя", "фамилия",
            ),
            массив(
                "Тимофей", "Беркут",
            ),
        ),
        "другой аргумент",
        массив(1, 2, 3),
    )
)
