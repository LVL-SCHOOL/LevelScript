ВКЛЮЧИТЬ стандартная_библиотека.аргументы_запуска
ВКЛЮЧИТЬ стандартная_библиотека.структуры.*
ВКЛЮЧИТЬ стандартная_библиотека.строки


ОПРЕДЕЛИТЬ ПРОЦЕДУРУ главная() (
    ЗАДАТЬ аргументы = получить_аргументы_запуска();

    ЕСЛИ НЕ аргументы ТО (
        ЗАДАТЬ временное_значение = массив("Привет", "мир!");

        НАПЕЧАТАТЬ "Аргументы не были получены, поэтому им будет присвоено стандартное значение!";
        НАПЕЧАТАТЬ "Чтобы использовать аргументы запуска, просто введите их после скрипта.";
        НАПЕЧАТАТЬ "Вот так:";
        НАПЕЧАТАТЬ форматировать_строку("\npy .\law.py --run .\examples\start_args.raw arg1 arg2\n");

        аргументы = временное_значение;
    )

    НАПЕЧАТАТЬ форматировать_строку("аргументы={}", аргументы);
)

ВЫПОЛНИТЬ (
    главная();
)
